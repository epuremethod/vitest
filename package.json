{
  "name": "epure-vitest-monorepo",
  "private": true,
  "version": "1.1.0",
  "description": "Monorepo for @epure/vitest and its documentation.",
  "homepage": "https://epurejs.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/epuremethod/vitest.git"
  },
  "scripts": {
    "build": "pnpm -r build",
    "canary": "./bin/publish.sh --canary",
    "beta": "./bin/publish.sh --beta",
    "format": "biome format --fix",
    "pub": "./bin/publish.sh",
    "test-app": "pnpm -filter test-app",
    "vitest": "pnpm -filter @epure/vitest",
    "test": "pnpm -r --workspace-concurrency=1 test",
    "test:watch": "pnpm -r test:watch"
  },
  "author": "Gaspard Anna Bucher <g.a.bucher@midasum.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@biomejs/biome": "^2.3.10"
  }
}
